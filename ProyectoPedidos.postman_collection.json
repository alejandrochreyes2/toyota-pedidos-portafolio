    {
      "name": "2. AUTENTICACIÓN",
      "description": "Pruebas de login con los 3 roles disponibles. Ejecutar primero para obtener los tokens JWT que se usarán en las demás carpetas.",
      "item": [
        {
          "name": "05 LOGIN Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@toyota.com\",\n    \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/usuarios/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "auth", "login"]
            },
            "description": "Autentica al usuario Administrador y guarda el token JWT automáticamente en la variable {{token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login Admin exitoso — status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta contiene token JWT', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('token', json.token);",
                  "});",
                  "pm.test('Rol es Admin', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.role).to.equal('Admin');",
                  "});",
                  "pm.test('Email correcto en respuesta', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.email).to.equal('admin@toyota.com');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "06 LOGIN Vendedor",
