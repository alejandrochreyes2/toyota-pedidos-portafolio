    {
      "name": "5. FLUJO COMPLETO END-TO-END",
      "description": "Flujo completo de negocio: Login → Crear Pedido → Registrar Pago → Verificar. Ejecutar en orden para simular un caso de uso real completo.",
      "item": [
        {
          "name": "20 [FLUJO] 1-Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@toyota.com\",\n    \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/usuarios/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "auth", "login"]
            },
            "description": "PASO 1: Autenticación del administrador para iniciar el flujo completo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[Flujo] Login exitoso', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "21 [FLUJO] 2-Crear Pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"cliente\": \"Concesionario Toyota Bogota\",\n    \"total\": 500000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/pedidos",
              "host": ["{{base_url}}"],
              "path": ["api", "pedidos"]
            },
            "description": "PASO 2: Crear un pedido de ejemplo para el flujo completo."
          },
